# This project runs inference against a LOCAL llama.cpp server (OpenAI-compatible).
# No API keys are required. Start the server with:
#   llama-server -hf Qwen/Qwen2.5-1.5B-Instruct-GGUF:Q4_K_M --port 8080 -ngl 99 -c 8192 --parallel 4
#
# Optional: override the local server URL (defaults to http://localhost:8080/v1)
# LLAMA_BASE_URL=http://localhost:8080/v1
